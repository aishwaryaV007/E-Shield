# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
*.pyd
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ───────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Testing / coverage ────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
